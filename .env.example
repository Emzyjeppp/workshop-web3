# Salin file ini menjadi .env lalu isi nilainya:  cp .env.example .env
# JANGAN commit file .env yang sudah berisi private key asli!

# RPC endpoint jaringan tujuan (contoh Sepolia dari Alchemy/Infura/publik)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/ISI_API_KEY_KAMU

# Private key akun untuk deploy (untuk Sepolia gunakan akun KHUSUS test, bukan akun utama)
PRIVATE_KEY=0xisi_private_key_test_kamu

# API key Etherscan untuk verifikasi kontrak (opsional)
ETHERSCAN_API_KEY=ISI_API_KEY_ETHERSCAN
